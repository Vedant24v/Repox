# Groq API Key for Phase 3 LLM tutorial generation
GROQ_API_KEY=
# Groq Model (optional, defaults to "llama-3.3-70b-versatile")
GROQ_MODEL=
# Backend storage directory (optional, defaults to "storage")
STORAGE_DIR=storage
# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000
